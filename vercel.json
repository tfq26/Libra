{
  "version": 2,
  "builds": [
    {
      "src": "Frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "Backend/api/conversation.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/conversation",
      "dest": "/Backend/api/conversation.js"
    },
    {
      "src": "/(.*)",
      "dest": "/Frontend/$1"
    }
  ]
}