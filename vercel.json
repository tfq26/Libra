{
  "version": 2,
  "builds": [
    {
      "src": "Frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "Backend/api/*.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/Backend/api/(.*)",
      "destination": "/Backend/api/$1" 
    },
    
    {
      "source": "/(.*)",
      "destination": "/Frontend/$1"
    }
  ]
}