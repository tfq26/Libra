{
  "version": 2,
  "builds": [
    {
      "src": "Frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "Backend/api/*",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/Backend/api/(.*)",
      "dest": "/Backend/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/Frontend/$1",
      "continue": true
    }
  ]
}