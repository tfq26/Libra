{
  "version": 2,
  "builds": [
    {
      "src": "Frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "Backend/api/*.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/Backend/api/conversation(.*)",
      "destination": "/Backend/api/conversation.js" 
    },
    
    {
      "source": "/Backend/api/history",
      "destination": "/Backend/api/history.js" 
    },
    
    {
      "source": "/(.*)",
      "destination": "/Frontend/$1"
    }
  ]
}