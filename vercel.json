{
  "version": 2,
  "builds": [
    {
      "src": "Frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "Backend/api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/Backend/api/conversation(.*)",
      "dest": "/Backend/api/conversation.js"
    },
    
    {
      "src": "/Backend/api/history",
      "dest": "/Backend/api/history.js"
    },
    
    {
      "src": "/(.*)",
      "dest": "/Frontend/dist/$1"
    }
  ]
}