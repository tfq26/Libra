{
  "version": 2,
  "builds": [
    {
      "src": "Frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "Backend/api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/Backend/api/conversation/:match*",
      "destination": "/Backend/api/conversation.js"
    },
    {
      "source": "/Backend/api/history/:match*",
      "destination": "/Backend/api/history.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
