{
  "name": "libra",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run dev:frontend\" \"bun run dev:backend\"",
    "dev:frontend": "cd Frontend && bun run dev",
    "dev:backend": "cd Backend && bun run dev",
    "build": "cd Frontend && bun run build",
    "start": "cd Frontend && bun run preview",
    "vercel-build": "bun run build",
    "preview": "cd Frontend && bun run preview",
    "build:backend": "cd Backend && bun run build",
    "start:backend": "cd Backend && bun run start"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "vercel": "^48.2.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}