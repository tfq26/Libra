{
  "name": "libra",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.1.12",
  "scripts": {
    "build": "turbo run build",
    "install": "bun install --cwd apps/Backend && bun install --cwd apps/frontend",
    "dev": "turbo run dev",
    "dev:vercel": "vercel dev",
    "dev:frontend": "turbo run dev --filter=frontend",
    "dev:backend": "turbo run dev --filter=libra-backend || (cd apps/Backend && bun run dev:server)",
    "build:frontend": "turbo run build --filter=frontend",
    "build:backend": "turbo run build --filter=libra-backend",
    "start": "turbo run start",
    "start:backend": "turbo run start --filter=libra-backend",
    "preview": "turbo run preview --filter=frontend",
    "vercel-build": "turbo run vercel-build",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "turbo": "^2.5.8",
    "@types/bun": "latest"
  },
  "dependencies": {
    "vercel": "^48.4.1"
  }
}