{
  "name": "libra",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "start:frontend": "cd Frontend && bun run dev",
    "start:backend": "cd Backend && func start",
    "install:all": "npm install -g concurrently && cd Frontend/nuxt-app && bun install && cd ../../Backend && npm install"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
