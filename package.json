{
  "name": "libra",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Libra - A modern web application to help everyone with their tech needs.",
  "author": "Taufeeq Ali",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd backend && npm start",
    "client": "cd frontend && npm run dev",
    "install-all": "npm install --prefix backend && npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^7.6.0"
  },
  "dependencies": {
    "@azure/functions": "^4.7.2-preview",
    "@azure/storage-blob": "^12.28.0",
    "@react-oauth/google": "^0.12.1",
    "axios": "1.11.0",
    "busboy": "^1.6.0",
    "cookie": "^0.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "2.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.10.0",
    "react-scripts": "5.0.1",
    "jwt-decode": "^4.0.0",
    "uuid": "^11.1.0"
  },
  "peerDependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
