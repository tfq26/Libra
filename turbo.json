{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".vercel/**"],
      "env": ["NODE_ENV"]
    },
    "build:backend": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "dev:frontend": {
      "cache": false,
      "persistent": true
    },
    "dev:backend": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "start:backend": {
      "dependsOn": ["build:backend"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": [],
      "cache": true
    },
    "format": {
      "outputs": [],
      "cache": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "preview": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "vercel-build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".vercel/**"],
      "env": ["NODE_ENV", "VERCEL", "VERCEL_ENV", "VERCEL_URL"]
    }
  },
  "globalEnv": [
    "NODE_ENV",
    "VERCEL",
    "VERCEL_ENV",
    "FIREBASE_SERVICE_ACCOUNT_BASE64",
    "AZURE_STORAGE_CONNECTION_STRING",
    "AZURE_STORAGE_ACCOUNT_NAME",
    "AZURE_STORAGE_ACCOUNT_KEY",
    "AZURE_STORAGE_BLOB_URL",
    "AZURE_STORAGE_CONTAINER",
    "MAX_IMAGE_UPLOAD_BYTES",
    "MAX_IMAGE_ATTACHMENTS",
    "ALLOWED_IMAGE_MIME_TYPES",
    "ATTACHMENT_SIGNED_URL_TTL_SECONDS",
    "OPENAI_API_KEY",
    "OPENAI_ENDPOINT",
    "COSMOSDB_CONNECTION_STRING",
    "AZURE_OPENAI_DEPLOYMENT_NAME"
  ]
}